{
  "expo": {
    "name": "WinrSwipe",
    "slug": "winrswipe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "winrswipe",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "primaryColor": "#FF4D1C",

    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.winrswipe.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "SwipeBid uses your camera to photograph items you want to sell.",
        "NSPhotoLibraryUsageDescription": "SwipeBid uses your photo library to upload product images.",
        "NSMicrophoneUsageDescription": "SwipeBid uses the microphone to record short product videos.",
        "NSLocationWhenInUseUsageDescription": "SwipeBid uses your location to show nearby auctions.",
        "NSUserNotificationsUsageDescription": "SwipeBid sends notifications when you are outbid or win an auction.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },

    "android": {
      "package": "com.winrswipe.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0D0D0D",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0D0D0D",
          "dark": {
            "backgroundColor": "#0D0D0D"
          }
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.winrswipe",
          "enableGooglePay": false
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "SwipeBid uses your camera to photograph items for sale."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SwipeBid uses your location to show nearby auctions."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FF4D1C",
          "sounds": []
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "f57101c9-eb2a-4ef9-a606-3135388f1218"
      }
    },

    "owner": "boaz65sa"
  }
}
